class Solution:
    def kthSmallest(self, nums, k):
          
        n=len(nums)
        heap=[]
        for ind in range(0,k):
            heapq.heappush(heap,-nums[ind])
        for ind in range (k,n):
            if (-nums[ind]>heap[0]):
                heapq.heappop(heap)
                heapq.heappush(heap,-nums[ind])
        return  -heap[0]


        
        
