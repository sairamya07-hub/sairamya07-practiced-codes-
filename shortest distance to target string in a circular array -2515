class Solution:
    def closestTarget(self, words: List[str], target: str, startIndex: int) -> int:
        if target not in words:
            return -1
        if words[startIndex]==target:
            return 0
        arr=[]
        l=list(words)
        for i in range(1,len(words)-1):
            if(words[(startIndex+i) % len(words)]==target):
                arr.append(i)
            if(words[(startIndex-i) % len(words)]==target):
                arr.append(i)
        return min(arr)
