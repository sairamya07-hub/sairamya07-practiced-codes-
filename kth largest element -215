import heapq
class Solution:
    def findKthLargest(self, nums: List[int], k: int) -> int:
        #nums.sort()
        #nums=nums[::-1]
        #return nums[k-1]
        n=len(nums)
        heap=[]
        for ind in range(0,k):
            heapq.heappush(heap,nums[ind])
        for ind in range (k,n):
            if (nums[ind]>heap[0]):
                heapq.heappop(heap)
                heapq.heappush(heap,nums[ind])
        return  heap[0]



        
